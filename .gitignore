CONTINUITY.md
.mcp.json
# docs/ holds both canonical harness documentation (tracked) and user-generated
# per-project content (ignored). The blanket-ignore rule was replaced with
# targeted excludes for the subdirs setup.sh creates in user projects.
docs/plans/
docs/prds/
docs/solutions/
docs/research/
docs/ci-templates/
.worktrees/

# tests/e2e/ is the user-runtime convention scaffolded by
# `setup.sh --with-playwright` into downstream projects. If this template
# repo ever gets run through its own setup.sh (e.g. while dogfooding),
# we don't want the scaffolded dir tracked. The template's own regression
# suite lives in tests/template/, which IS tracked.
tests/e2e/

# Volatile per-developer workflow state (PR #2 / continuity-split)
.claude/local/
